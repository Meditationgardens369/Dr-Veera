            <!-- ═══════════ SECTION: UNDERSTANDING ═══════════ -->
            <section id="s-understanding" class="section">
                <div class="glass-warm rounded-3xl p-8 mb-6">
                    <div class="tag bg-moss-400/10 text-moss-200 border border-moss-400/20 mb-4">What we understood about you</div>
                    <h2 class="serif text-4xl font-light text-cream-50 leading-tight mb-4">Before we designed anything, we studied your work.</h2>
                    <p class="text-ink-200 leading-relaxed max-w-3xl">Your training, your philosophy, the way you speak about food and digestion, your clinical depth, and the kinds of people who find their way to Samayur. Below is what shaped every decision in this demonstration.</p>
                </div>

                <div class="grid grid-cols-2 gap-5 mb-6">
                    <div class="card glass rounded-2xl p-6">
                        <div class="text-[10px] uppercase tracking-widest text-saffron-200 font-semibold mb-3">Your clinical authority</div>
