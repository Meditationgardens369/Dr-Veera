        .section { display: none; }
        .section.active { display: block; animation: fadeUp 0.5s ease-out; }

        .card { transition: transform 0.25s ease, box-shadow 0.25s ease; }
        .card:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(0,0,0,0.35); }

        .slider { -webkit-appearance:none; appearance:none; width:100%; height:4px; border-radius:2px; background: linear-gradient(to right, #647a48 0%, #647a48 var(--v,50%), #221a12 var(--v,50%), #221a12 100%); outline:none; }
        .slider::-webkit-slider-thumb { -webkit-appearance:none; width:20px; height:20px; border-radius:50%; background:#c9b384; cursor:pointer; box-shadow:0 0 12px rgba(201,179,132,0.5); transition: transform 0.15s; }
        .slider::-webkit-slider-thumb:hover { transform: scale(1.2); }

        /* Chat */
        .chat-wrap { background: radial-gradient(ellipse at top, rgba(100,122,72,0.08), transparent 60%), #0d0906; border: 1px solid rgba(253,250,242,0.08); }
        .bubble-bot { background: linear-gradient(135deg, rgba(163,181,128,0.12), rgba(100,122,72,0.06)); border:1px solid rgba(163,181,128,0.18); }
        .bubble-user { background: linear-gradient(135deg, rgba(226,153,74,0.14), rgba(197,141,66,0.08)); border:1px solid rgba(226,153,74,0.2); }
        .typing span { display:inline-block; width:6px; height:6px; margin:0 1px; background:#a3b580; border-radius:50%; animation: pulse-dot 1.4s infinite; }
        .typing span:nth-child(2){animation-delay:0.2s;}
        .typing span:nth-child(3){animation-delay:0.4s;}

        .prompt-chip { transition: all 0.2s ease; cursor: pointer; }
        .prompt-chip:hover { background: rgba(163,181,128,0.15); border-color: rgba(163,181,128,0.4); transform: translateY(-1px); }

        .lotus { width:44px; height:44px; background: radial-gradient(circle, #c9b384 0%, #7e461a 80%); border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'Cormorant Garamond',serif; font-weight:600; color:#15100a; }

        .tag { display:inline-flex; align-items:center; gap:6px; padding:4px 12px; border-radius:9999px; font-size:0.65rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; }

        .divider { height:1px; background: linear-gradient(to right, transparent, rgba(201,179,132,0.3), transparent); }

        .number-display { background: linear-gradient(135deg, #c9b384, #e2994a); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

        .phone-frame { background: #0d0906; border: 10px solid #221a12; border-radius: 40px; box-shadow: 0 20px 60px rgba(0,0,0,0.6), inset 0 2px 4px rgba(255,255,255,0.05); }
    </style>
